{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dotnet: restore",
      "type": "shell",
      "command": "dotnet restore",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: build",
      "type": "shell",
      "command": "dotnet build --no-restore",
      "dependsOn": "dotnet: restore",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: test",
      "type": "shell",
      "command": "dotnet test --no-build",
      "group": "test",
      "problemMatcher": "$msCompile"
    }
  ]
}
