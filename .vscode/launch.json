{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET: Debug Console",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build",
      "program": "${workspaceFolder}/src/VSlices.Tooling/bin/Debug/net10.0/VSlices.Tooling.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/VSlices.Tooling",
      "stopAtEntry": false,
      "console": "integratedTerminal"
    },
    {
      "name": ".NET: Attach to process",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}